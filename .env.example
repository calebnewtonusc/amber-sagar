# Claude / Anthropic
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Loop Message (iMessage delivery — https://loopmessage.com)
LOOP_AUTH_KEY=your_loop_auth_key
LOOP_SECRET_KEY=your_loop_secret_key
LOOP_SENDER_NAME=your.sender@imsg.co
SAGAR_PHONE_NUMBER=+1xxxxxxxxxx

# GitHub (message polling + context loading)
GITHUB_TOKEN=ghp_...
GITHUB_MESSAGES_REPO=calebnewtonusc/sagar-amber-messages
GITHUB_CONTEXT_REPO=calebnewtonusc/sagar-context

# Amber Core API (optional — enables structured memory)
AMBER_API_URL=https://amber-api.railway.app
AMBER_API_KEY=your_amber_api_key

# Agent behavior
POLL_INTERVAL=2000
PORT=3000
