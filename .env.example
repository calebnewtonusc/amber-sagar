# Claude / Anthropic
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Poke (iMessage delivery)
POKE_API_KEY=your_poke_api_key

# GitHub (message polling + context loading)
GITHUB_TOKEN=ghp_...
GITHUB_MESSAGES_REPO=calebnewtonusc/sagar-amber-messages
GITHUB_CONTEXT_REPO=calebnewtonusc/sagar-context

# Amber Core API (optional — enables structured memory)
AMBER_API_URL=https://amber-api.railway.app
AMBER_API_KEY=your_amber_api_key

# Agent behavior
POLL_INTERVAL=2000
PORT=3000
